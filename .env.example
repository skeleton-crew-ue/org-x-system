# Copy this file to `.env` and fill in the values. Never commit `.env`.

# --- Required ---
DEBUG=True
SECRET_KEY=dev-not-a-real-secret-generate-a-real-one-for-prod
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (pick ONE) ---
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://yourname@localhost:5432/org_x_system

# --- Email (local dev: use Mailtrap; leave blank to print emails to console) ---
EMAIL_HOST=
EMAIL_PORT=2525
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Org X Dev <noreply@orgx.local>

# --- Misc ---
TIME_ZONE=Europe/Berlin

# --- Production only (set in Render's env vars, not here) ---
# CSRF_TRUSTED_ORIGINS=https://org-x-system.onrender.com
# MEDIA_ROOT=/opt/render/project/media
